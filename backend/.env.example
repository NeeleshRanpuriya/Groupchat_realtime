# Database Configuration (choose one)
# For SQLite (simpler for college demo):
DATABASE_URL=sqlite:///./chat_moderation.db
# For PostgreSQL (if you have a local server):
# DATABASE_URL=postgresql://user:password@localhost:5432/chat_moderation

# OpenAI API Key – REPLACE WITH YOUR ACTUAL KEY
OPENAI_API_KEY=your_openai_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000

# ML Model Configuration (optional, currently not used)
TOXICITY_MODEL=unitary/toxic-bert
MAX_LENGTH=512

# CORS – frontend URL (for production, change to deployed URL)
FRONTEND_URL=http://localhost:3000

SECRET_KEY=your-strong-secret-key-here

CLOUDINARY_CLOUD_NAME=enter your cloud name here
CLOUDINARY_API_KEY=enter your api key here
CLOUDINARY_API_SECRET=enter your api secret here